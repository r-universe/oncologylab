	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "craftgrn"]
	path = craftgrn
	url = https://github.com/oncologylab/craftgrn
[submodule "enrichly"]
	path = enrichly
	url = https://github.com/oncologylab/enrichly
	registered = false
